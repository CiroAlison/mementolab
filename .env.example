# ——— MementoLab · variabili d'ambiente ———
# Copia questo file in .env.local (sviluppo) e configura le stesse variabili
# su Vercel (Project Settings → Environment Variables) per la produzione.

# Database Neon (Postgres serverless).
# Crea un progetto su https://neon.tech e incolla la "Connection string".
# Finché è vuoto, i form funzionano ma le richieste NON vengono salvate.
DATABASE_URL=

# Notifiche email via Resend (https://resend.com) — opzionale.
# Senza questa chiave, i form funzionano ma non viene inviata l'email.
RESEND_API_KEY=
# Mittente verificato su Resend (es. "MementoLab <info@tuodominio.it>").
NOTIFY_FROM=
# Destinatario delle notifiche (default: email in src/lib/site.ts).
NOTIFY_TO=
